---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/privacy/", label: "Privacy" },
  { href: "/support/", label: "Support" },
];

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) =>
  `${baseUrl}${path.replace(/^\//, "")}`;
const isCurrent = (path: string) =>
  currentPath === path || currentPath === withBase(path);
const pageUrl = new URL(currentPath, Astro.site ?? Astro.url.origin);
const previewImageUrl = new URL(withBase("/preview.png"), Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:site_name" content="NextMetro" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={previewImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="NextMetro Apple Watch commute timing preview" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={previewImageUrl} />
    <meta name="twitter:image:alt" content="NextMetro Apple Watch commute timing preview" />
    <meta name="theme-color" content="#0d161b" />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />
    <link rel="manifest" href={withBase("/site.webmanifest")} />
    <title>{title}</title>
  </head>
  <body>
    <header class="header-wrap">
      <div class="site-header" aria-label="Primary navigation">
        <a class="brand" href={withBase("/")} aria-label="NextMetro home">
          <span class="brand-mark" aria-hidden="true">
            <span class="brand-clock"></span>
            <span class="brand-route"></span>
          </span>
          <span>NextMetro</span>
        </a>
        <nav>
          {
            navItems.map((item) => (
              <a
              href={withBase(item.href)}
              aria-current={isCurrent(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div>
        <a class="brand compact" href={withBase("/")}>
          <span class="brand-mark" aria-hidden="true">
            <span class="brand-clock"></span>
            <span class="brand-route"></span>
          </span>
          <span>NextMetro</span>
        </a>
        <p>Know when to leave for the next train.</p>
        <p class="footer-disclaimer">
          NextMetro is an independent app and is not affiliated with WMATA.
        </p>
      </div>
      <nav aria-label="Footer navigation">
        <a href={withBase("/privacy/")}>Privacy</a>
        <a href={withBase("/support/")}>Support</a>
        <a href="mailto:support@nextmetro.app">support@nextmetro.app</a>
      </nav>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #0d161b;
    --bg-deep: #070d10;
    --surface: #132027;
    --surface-strong: #192a31;
    --line: rgba(232, 247, 239, 0.13);
    --line-strong: rgba(232, 247, 239, 0.2);
    --text: #f5faf7;
    --muted: #9db5aa;
    --soft: #dbe9e3;
    --green: #00a94f;
    --mint: #60eba2;
    --yellow: #ffd166;
    --cyan: #57c7ff;
    --max: 1180px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    min-width: 320px;
    margin: 0;
    background:
      radial-gradient(circle at 80% -10%, rgba(87, 199, 255, 0.18), transparent 26rem),
      radial-gradient(circle at 14% 4%, rgba(96, 235, 162, 0.16), transparent 30rem),
      linear-gradient(160deg, var(--bg) 0%, #101d22 46%, var(--bg-deep) 100%);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    text-rendering: geometricPrecision;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  p {
    color: var(--muted);
    line-height: 1.65;
  }

  .header-wrap {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid rgba(232, 247, 239, 0.08);
    background: rgba(7, 13, 16, 0.58);
    backdrop-filter: blur(24px) saturate(1.5);
  }

  .site-footer {
    width: min(var(--max), calc(100% - 40px));
    margin: 0 auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    width: min(var(--max), calc(100% - 40px));
    margin: 0 auto;
    padding: 13px 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    font-weight: 760;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .brand.compact {
    font-size: 0.98rem;
  }

  .brand-mark {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    flex: 0 0 auto;
    border: 2px solid var(--green);
    border-radius: 50%;
    background: #0d161b;
    box-shadow:
      0 0 0 6px rgba(0, 169, 79, 0.12),
      0 14px 34px rgba(0, 169, 79, 0.18);
  }

  .brand-clock::before,
  .brand-clock::after {
    position: absolute;
    top: 9px;
    left: 17px;
    width: 3px;
    height: 11px;
    border-radius: 999px;
    background: var(--text);
    content: "";
    transform-origin: 50% 100%;
  }

  .brand-clock::after {
    top: 17px;
    left: 18px;
    width: 11px;
    height: 3px;
    background: var(--soft);
    transform: rotate(24deg);
    transform-origin: 0 50%;
  }

  .brand-route {
    position: absolute;
    right: 6px;
    bottom: 8px;
    left: 6px;
    height: 3px;
    border-radius: 999px;
    background: var(--green);
  }

  .brand-route::before,
  .brand-route::after {
    position: absolute;
    top: -3px;
    width: 9px;
    height: 9px;
    border: 2px solid var(--green);
    border-radius: 50%;
    background: var(--bg);
    content: "";
  }

  .brand-route::before {
    left: -1px;
  }

  .brand-route::after {
    right: -1px;
  }

  .site-header nav,
  .site-footer nav {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .site-header nav a,
  .site-footer nav a {
    border: 1px solid transparent;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 680;
  }

  .site-header nav a {
    padding: 8px 12px;
  }

  .site-header nav a:hover,
  .site-header nav a[aria-current="page"] {
    border-color: var(--line);
    background: rgba(245, 250, 247, 0.07);
    color: var(--text);
  }

  main {
    overflow: hidden;
  }

  .section {
    width: min(var(--max), calc(100% - 40px));
    margin: 0 auto;
    padding: 88px 0;
  }

  .section.tight {
    padding-top: 66px;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--mint);
    font-size: 0.76rem;
    font-weight: 820;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: 0;
    line-height: 1.02;
  }

  h1 {
    max-width: 860px;
    font-size: clamp(3.6rem, 9vw, 8.4rem);
    font-weight: 880;
  }

  h2 {
    max-width: 820px;
    font-size: clamp(2.1rem, 4.5vw, 4.2rem);
    font-weight: 820;
  }

  h3 {
    font-size: 1.08rem;
    font-weight: 760;
  }

  .lead {
    max-width: 700px;
    margin: 24px 0 0;
    color: var(--soft);
    font-size: clamp(1.16rem, 2vw, 1.52rem);
    line-height: 1.45;
  }

  .button-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border: 1px solid transparent;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 760;
    box-shadow: 0 18px 38px rgba(0, 0, 0, 0.18);
    transition:
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button.primary {
    background: linear-gradient(135deg, var(--mint), var(--green));
    color: #06100b;
  }

  .button.secondary {
    border-color: var(--line);
    color: var(--text);
  }

  .grid {
    display: grid;
    gap: 16px;
  }

  .grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .panel {
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), transparent),
      rgba(19, 32, 39, 0.72);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .feature {
    min-height: 250px;
    padding: 26px;
  }

  .feature p {
    margin: 14px 0 0;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding: 42px 0 52px;
    border-top: 1px solid var(--line);
  }

  .site-footer p {
    margin: 12px 0 0;
    font-size: 0.95rem;
  }

  .site-footer .footer-disclaimer {
    max-width: 460px;
    font-size: 0.82rem;
  }

  .site-footer nav a {
    padding: 5px 0 5px 12px;
  }

  .content-page {
    max-width: 880px;
  }

  .content-block {
    margin-top: 36px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
  }

  .content-block h2 {
    font-size: clamp(1.45rem, 3vw, 2.05rem);
    line-height: 1.12;
  }

  .content-block p,
  .content-block li {
    color: var(--muted);
    line-height: 1.7;
  }

  .content-block ul {
    padding-left: 1.2rem;
  }

  .contact-panel {
    display: grid;
    gap: 14px;
    margin-top: 36px;
    padding: 28px;
  }

  @media (max-width: 760px) {
    .header-wrap {
      position: static;
    }

    .site-header {
      align-items: flex-start;
      flex-direction: column;
      padding: 18px 0;
    }

    .site-header nav {
      justify-content: flex-start;
    }

    .section {
      width: min(var(--max), calc(100% - 32px));
      padding: 62px 0;
    }

    .grid.three {
      grid-template-columns: 1fr;
    }

    .site-footer {
      flex-direction: column;
    }

    .site-footer nav {
      justify-content: flex-start;
    }
  }
</style>
